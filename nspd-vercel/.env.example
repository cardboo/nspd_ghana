# ──────────────────────────────────────────────
# NSPD Ghana — environment configuration
# Copy to .env for local development. In production, set these in the
# Vercel dashboard (Project Settings -> Environment Variables).
# Never commit the real .env file.
# ──────────────────────────────────────────────

# Option A: full SQLAlchemy URL (takes precedence when set)
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/nspd_db?charset=utf8mb4

# Option B: individual parts (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=nspd_db

# Set to true for cloud MySQL providers that require TLS (PlanetScale, Aiven, ...)
DB_SSL=false

# JWT signing secret — generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# Access token lifetime in hours
JWT_EXPIRES_HOURS=8

# Cookie Secure flag: auto (secure on Vercel, not locally) | true | false
COOKIE_SECURE=auto

# ── Login throttling ──
# Failed attempts per username before lockout (per-IP limit is 4x this)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=15

# ── Applicant email notifications (status changes) ──
# Without RESEND_API_KEY, emails are recorded in the notifications table
# with status 'skipped' instead of being sent. Get a key at resend.com.
RESEND_API_KEY=
EMAIL_FROM=NSPD Ghana <onboarding@resend.dev>

# ── Document storage ──
# auto = Vercel Blob when BLOB_READ_WRITE_TOKEN is set, local disk otherwise.
# On Vercel you MUST use Blob (serverless instances have no persistent disk):
# create a Blob store in the Vercel dashboard and it injects the token.
STORAGE_DRIVER=auto
BLOB_READ_WRITE_TOKEN=
# Local-driver settings (development)
# UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=10
