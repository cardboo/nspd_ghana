{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": ["backend/**"] }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/frontend/login.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "crons": [
    { "path": "/api/cron/cleanup-unverified", "schedule": "0 3 * * *" }
  ]
}
